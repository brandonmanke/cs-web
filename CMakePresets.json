{
  "version": 6,
  "configurePresets": [
    {
      "name": "native",
      "displayName": "Native (tests + future server)",
      "binaryDir": "${sourceDir}/build/native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native",
      "configurePreset": "native"
    }
  ],
  "testPresets": [
    {
      "name": "native",
      "configurePreset": "native",
      "output": { "outputOnFailure": true }
    }
  ]
}
