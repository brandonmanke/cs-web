{
  "name": "cs-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run wasm && npm run typecheck && vite build",
    "preview": "vite preview",
    "wasm": "emcmake cmake -B build/wasm -DCMAKE_BUILD_TYPE=Release -DBOX3D_DISABLE_SIMD=ON && cmake --build build/wasm -j",
    "test": "cmake --preset native && cmake --build --preset native -j && ctest --preset native",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/three": "^0.182.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
