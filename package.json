{
  "name": "cs-web",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sim:native": "cmake --preset native && cmake --build --preset native",
    "sim:test": "npm run sim:native && ctest --preset native",
    "game:wasm": "EM_CACHE=$PWD/.cache/emscripten emcmake cmake --preset wasm && EM_CACHE=$PWD/.cache/emscripten cmake --build --preset wasm",
    "build": "npm run game:wasm",
    "dev": "npm run game:wasm && node tools/serve.mjs"
  }
}
